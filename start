#!/usr/bin/env bash
# Start all threat detection services (Postgres, Engine, Dashboard) via Docker Compose.

set -e
cd "$(dirname "$0")"

if ! command -v docker &>/dev/null; then
  echo "Error: Docker is not installed or not in PATH." >&2
  exit 1
fi

if ! sudo docker compose version &>/dev/null; then
  echo "Error: Docker Compose is not available. Install the Docker Compose plugin." >&2
  exit 1
fi

echo "Starting threat detection services..."
sudo docker compose up -d --build

echo "Waiting for services to be ready..."
for i in {1..30}; do
  if curl -s -o /dev/null -w "%{http_code}" http://localhost:8000/health 2>/dev/null | grep -q 200; then
    echo ""
    echo "All services are up."
    echo "  Engine:    http://localhost:8000"
    echo "  API docs: http://localhost:8000/docs"
    echo "  Dashboard: http://localhost:5173"
    exit 0
  fi
  printf "."
  sleep 2
done

echo ""
echo "Services started; engine may still be initializing."
echo "  Engine:    http://localhost:8000"
echo "  Dashboard: http://localhost:5173"
